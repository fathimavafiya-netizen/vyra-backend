{
  "name": "vyra-backend",
  "version": "1.0.0",
  "description": "Backend API and Socket.IO server for Vyra Social Media Application",
  "main": "dist/server.js",
  "scripts": {
    "build": "npx prisma generate && tsc",
    "start": "node dist/server.js",
    "start:prod": "pm2 start ecosystem.config.js --env production",
    "stop:prod": "pm2 stop ecosystem.config.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "seed": "ts-node prisma/seed.ts",
    "test": "jest --forceExit"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@google-cloud/storage": "^5.18.3",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "5.22.0",
    "prisma": "5.22.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "firebase-admin": "^10.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "google-auth-library": "^10.9.0",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "libphonenumber-js": "^1.13.8",
    "multer": "^1.4.5-lts.1",
    "pino": "^9.2.0",
    "resend": "^6.17.1",
    "sharp": "^0.35.3",
    "socket.io": "^4.7.5",
    "twilio": "^6.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.2",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "pino-pretty": "^11.2.1",
    "pm2": "^7.0.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
